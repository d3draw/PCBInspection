# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environment
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp

# Data (runtime, not tracked).
# Use data/* (not data/) so re-includes for the QA-curated criteria assets
# below actually take effect — git can't un-prune a fully-excluded directory.
data/*
datasets/
# QA-curated criteria assets (borderline samples + schema) — see
# docs/INSPECTION_CRITERIA.md §4. Schema, .gitkeeps and meta JSON are tracked;
# captured images stay out via the *.png line below.
!data/criteria/
!data/criteria/**
data/criteria/**/*.png
transistor/
results/
pre_trained/
*.onnx
*.engine
*.trt

# Jupyter
.ipynb_checkpoints/

# OS
Thumbs.db
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/

# Vendor SDK installers (do not commit — distribute via vendor)
*.whl
*.exe

# Debug screenshots
[0-9].png
[0-9][0-9].png
